NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/graduation_project_db?schema=public
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d
