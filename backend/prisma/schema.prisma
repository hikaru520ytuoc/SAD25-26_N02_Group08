generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  LOCKED
}

enum AuditResult {
  SUCCESS
  FAILED
}

enum InternshipStatus {
  NOT_COMPLETED
  COMPLETED
  WAIVED
}

enum AcademicStatus {
  ACTIVE
  SUSPENDED
  GRADUATED
  DROPPED
}

enum ProjectPeriodStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

enum EligibilityStatus {
  PENDING
  ELIGIBLE
  NOT_ELIGIBLE
}

enum TopicStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PUBLISHED
  CLOSED
}

enum TopicSource {
  SUPERVISOR_PROPOSED
  STUDENT_PROPOSED
}

enum TopicRegistrationType {
  EXISTING_TOPIC
  STUDENT_PROPOSED
}

enum SupervisorResponseStatus {
  NOT_REQUIRED
  PENDING
  ACCEPTED
  REJECTED
}

enum TopicRegistrationStatus {
  DRAFT
  PENDING_SUPERVISOR
  PENDING_FACULTY
  NEEDS_REVISION
  FACULTY_APPROVED
  FACULTY_REJECTED
  CANCELLED
  OFFICIALLY_ASSIGNED
}

enum SupervisorAssignmentType {
  TOPIC_OWNER
  STUDENT_REQUESTED
  FACULTY_ASSIGNED
}

enum SupervisorAssignmentStatus {
  ACTIVE
  CANCELLED
}

enum OutlineStatus {
  SUBMITTED
  NEEDS_REVISION
  APPROVED
  REJECTED
}

enum ProjectProgressStatus {
  SUBMITTED
  REVIEWED
}

enum FileDocumentType {
  OUTLINE
  PROGRESS_DRAFT
  REPORT
  SLIDE
  REVISION
  ARCHIVE
  OTHER
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  fullName     String
  phone        String?
  avatarUrl    String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  userRoles UserRole[]
  auditLogs AuditLog[] @relation("AuditActor")
  student   Student?
  lecturer  Lecturer?

  createdProjectPeriods ProjectPeriod[] @relation("ProjectPeriodCreator")
  checkedEligibilities   StudentEligibility[] @relation("EligibilityChecker")
  approvedTopics         Topic[] @relation("TopicApprover")
  confirmedRegistrations TopicRegistration[] @relation("RegistrationConfirmer")
  assignedSupervisors    SupervisorAssignment[] @relation("SupervisorAssignmentAssigner")
  reviewedOutlines       Outline[] @relation("OutlineReviewer")
  progressComments       ProjectProgressComment[] @relation("ProgressCommenter")
  ownedFileDocuments     FileDocument[] @relation("FileOwner")
  uploadedFileDocuments  FileDocument[] @relation("FileUploader")
  notifications          Notification[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model AuditLog {
  id         String      @id @default(uuid())
  actorId    String?
  actorEmail String?
  action     String
  targetType String?
  targetId   String?
  ipAddress  String?
  userAgent  String?
  result     AuditResult
  reason     String?
  createdAt  DateTime    @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Faculty {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students  Student[]
  lecturers Lecturer[]

  @@map("faculties")
}

model Student {
  id               String           @id @default(uuid())
  userId           String           @unique
  studentCode      String           @unique
  className        String
  major            String
  facultyId        String?
  internshipStatus InternshipStatus @default(NOT_COMPLETED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  faculty               Faculty?               @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  eligibilities         StudentEligibility[]
  topicRegistrations    TopicRegistration[]
  supervisorAssignments SupervisorAssignment[]
  outlines              Outline[]
  projectProgresses     ProjectProgress[]
  proposedTopics        Topic[]                @relation("TopicProposedByStudent")

  @@map("students")
}

model Lecturer {
  id                    String   @id @default(uuid())
  userId                String   @unique
  lecturerCode          String   @unique
  academicRank          String?
  department            String?
  facultyId             String?
  maxSupervisedStudents Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  faculty                      Faculty?               @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  topics                       Topic[]
  requestedTopicRegistrations  TopicRegistration[]
  supervisorAssignments        SupervisorAssignment[]
  supervisedOutlines           Outline[]
  supervisedProjectProgresses  ProjectProgress[]

  @@map("lecturers")
}

model ProjectPeriod {
  id                    String              @id @default(uuid())
  name                  String
  academicYear          String
  semester              String
  startDate             DateTime
  endDate               DateTime
  registrationStartDate DateTime?
  registrationEndDate   DateTime?
  status                ProjectPeriodStatus @default(DRAFT)
  createdById           String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  createdBy             User                   @relation("ProjectPeriodCreator", fields: [createdById], references: [id], onDelete: Restrict)
  eligibilities         StudentEligibility[]
  topics                Topic[]
  topicRegistrations    TopicRegistration[]
  supervisorAssignments SupervisorAssignment[]
  outlines              Outline[]
  projectProgresses     ProjectProgress[]

  @@map("project_periods")
}

model StudentEligibility {
  id                String            @id @default(uuid())
  studentId         String
  projectPeriodId   String
  internshipStatus  InternshipStatus
  academicStatus    AcademicStatus    @default(ACTIVE)
  eligibilityStatus EligibilityStatus @default(PENDING)
  reason            String?
  checkedById       String
  checkedAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  projectPeriod ProjectPeriod @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  checkedBy     User          @relation("EligibilityChecker", fields: [checkedById], references: [id], onDelete: Restrict)

  @@unique([studentId, projectPeriodId])
  @@map("student_eligibilities")
}

model Topic {
  id                  String      @id @default(uuid())
  title               String
  description         String
  objectives          String?
  expectedOutput      String?
  major               String?
  maxStudents         Int         @default(1)
  supervisorId        String
  projectPeriodId     String
  status              TopicStatus @default(DRAFT)
  source              TopicSource @default(SUPERVISOR_PROPOSED)
  proposedByStudentId String?
  rejectionReason     String?
  approvedById        String?
  approvedAt          DateTime?
  publishedAt         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  supervisor            Lecturer               @relation(fields: [supervisorId], references: [id], onDelete: Restrict)
  projectPeriod         ProjectPeriod          @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  proposedByStudent     Student?               @relation("TopicProposedByStudent", fields: [proposedByStudentId], references: [id], onDelete: SetNull)
  approvedBy            User?                  @relation("TopicApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  topicRegistrations    TopicRegistration[]
  supervisorAssignments SupervisorAssignment[]
  @@map("topics")
}

model TopicRegistration {
  id                       String                   @id @default(uuid())
  studentId                String
  projectPeriodId          String
  registrationType         TopicRegistrationType
  topicId                  String?
  proposedTitle            String?
  proposedDescription      String?
  proposedObjectives       String?
  proposedExpectedOutput   String?
  proposedMajor            String?
  requestedSupervisorId    String?
  supervisorResponseStatus SupervisorResponseStatus @default(NOT_REQUIRED)
  supervisorResponseNote   String?
  status                   TopicRegistrationStatus  @default(DRAFT)
  facultyNote              String?
  rejectedReason           String?
  confirmedById            String?
  confirmedAt              DateTime?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  student             Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  projectPeriod       ProjectPeriod         @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  topic               Topic?                @relation(fields: [topicId], references: [id], onDelete: SetNull)
  requestedSupervisor Lecturer?             @relation(fields: [requestedSupervisorId], references: [id], onDelete: SetNull)
  confirmedBy         User?                 @relation("RegistrationConfirmer", fields: [confirmedById], references: [id], onDelete: SetNull)
  supervisorAssignment SupervisorAssignment?
  outline              Outline?

  @@index([studentId, projectPeriodId])
  @@index([status])
  @@map("topic_registrations")
}

model SupervisorAssignment {
  id                  String                     @id @default(uuid())
  topicRegistrationId String                     @unique
  studentId           String
  topicId             String?
  projectPeriodId     String
  supervisorId        String
  assignedById        String
  assignmentType      SupervisorAssignmentType
  status              SupervisorAssignmentStatus @default(ACTIVE)
  assignedAt          DateTime                   @default(now())
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  topicRegistration TopicRegistration @relation(fields: [topicRegistrationId], references: [id], onDelete: Cascade)
  student           Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  topic             Topic?            @relation(fields: [topicId], references: [id], onDelete: SetNull)
  projectPeriod     ProjectPeriod     @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  supervisor        Lecturer          @relation(fields: [supervisorId], references: [id], onDelete: Restrict)
  assignedBy        User              @relation("SupervisorAssignmentAssigner", fields: [assignedById], references: [id], onDelete: Restrict)
  outlines          Outline[]
  projectProgresses ProjectProgress[]

  @@unique([studentId, projectPeriodId])
  @@index([supervisorId])
  @@map("supervisor_assignments")
}

model Outline {
  id                     String        @id @default(uuid())
  topicRegistrationId    String        @unique
  supervisorAssignmentId String
  studentId              String
  supervisorId           String
  projectPeriodId        String
  title                  String
  summary                String
  objectives             String?
  methodology            String?
  expectedOutput         String?
  timeline               String?
  status                 OutlineStatus @default(SUBMITTED)
  currentVersion         Int           @default(1)
  submittedAt            DateTime      @default(now())
  reviewedAt             DateTime?
  reviewedById           String?
  feedback               String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  topicRegistration    TopicRegistration    @relation(fields: [topicRegistrationId], references: [id], onDelete: Cascade)
  supervisorAssignment SupervisorAssignment @relation(fields: [supervisorAssignmentId], references: [id], onDelete: Cascade)
  student              Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  supervisor           Lecturer             @relation(fields: [supervisorId], references: [id], onDelete: Restrict)
  projectPeriod        ProjectPeriod        @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  reviewedBy           User?                @relation("OutlineReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  versions             OutlineVersion[]

  @@index([studentId])
  @@index([supervisorId])
  @@index([status])
  @@map("outlines")
}

model OutlineVersion {
  id             String   @id @default(uuid())
  outlineId      String
  versionNumber  Int
  title          String
  summary        String
  objectives     String?
  methodology    String?
  expectedOutput String?
  timeline       String?
  fileDocumentId String?
  submitNote     String?
  submittedAt    DateTime @default(now())
  createdAt      DateTime @default(now())

  outline      Outline       @relation(fields: [outlineId], references: [id], onDelete: Cascade)
  fileDocument FileDocument? @relation("OutlineVersionFile", fields: [fileDocumentId], references: [id], onDelete: SetNull)

  @@unique([outlineId, versionNumber])
  @@map("outline_versions")
}

model ProjectProgress {
  id                     String                @id @default(uuid())
  studentId              String
  supervisorId           String
  supervisorAssignmentId String
  projectPeriodId        String
  title                  String
  content                String
  progressPercent        Int?
  status                 ProjectProgressStatus @default(SUBMITTED)
  fileDocumentId         String?
  submittedAt            DateTime              @default(now())
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  student              Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  supervisor           Lecturer             @relation(fields: [supervisorId], references: [id], onDelete: Restrict)
  supervisorAssignment SupervisorAssignment @relation(fields: [supervisorAssignmentId], references: [id], onDelete: Cascade)
  projectPeriod        ProjectPeriod        @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  fileDocument         FileDocument?        @relation("ProjectProgressFile", fields: [fileDocumentId], references: [id], onDelete: SetNull)
  comments             ProjectProgressComment[]

  @@index([studentId])
  @@index([supervisorId])
  @@index([supervisorAssignmentId])
  @@map("project_progress")
}

model ProjectProgressComment {
  id          String   @id @default(uuid())
  progressId  String
  commenterId String
  comment     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress  ProjectProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  commenter User            @relation("ProgressCommenter", fields: [commenterId], references: [id], onDelete: Cascade)

  @@index([progressId])
  @@map("project_progress_comments")
}

model FileDocument {
  id           String           @id @default(uuid())
  ownerId      String
  originalName String
  storedName   String
  bucket       String
  objectKey    String
  mimeType     String
  size         Int
  fileType     FileDocumentType @default(OTHER)
  relatedType  String?
  relatedId    String?
  uploadedById String
  createdAt    DateTime         @default(now())
  deletedAt    DateTime?

  owner                User              @relation("FileOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  uploadedBy           User              @relation("FileUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  outlineVersions      OutlineVersion[]  @relation("OutlineVersionFile")
  projectProgressItems ProjectProgress[] @relation("ProjectProgressFile")

  @@index([ownerId])
  @@index([relatedType, relatedId])
  @@map("file_documents")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}
