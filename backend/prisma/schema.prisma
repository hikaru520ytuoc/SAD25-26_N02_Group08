generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  LOCKED
}

enum AuditResult {
  SUCCESS
  FAILED
}

enum InternshipStatus {
  NOT_COMPLETED
  COMPLETED
  WAIVED
}

enum AcademicStatus {
  ACTIVE
  SUSPENDED
  GRADUATED
  DROPPED
}

enum ProjectPeriodStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

enum EligibilityStatus {
  PENDING
  ELIGIBLE
  NOT_ELIGIBLE
}

enum TopicStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PUBLISHED
  CLOSED
}

enum TopicSource {
  SUPERVISOR_PROPOSED
  STUDENT_PROPOSED
}

enum TopicRegistrationType {
  EXISTING_TOPIC
  STUDENT_PROPOSED
}

enum SupervisorResponseStatus {
  NOT_REQUIRED
  PENDING
  ACCEPTED
  REJECTED
}

enum TopicRegistrationStatus {
  DRAFT
  PENDING_SUPERVISOR
  PENDING_FACULTY
  NEEDS_REVISION
  FACULTY_APPROVED
  FACULTY_REJECTED
  CANCELLED
  OFFICIALLY_ASSIGNED
}

enum SupervisorAssignmentType {
  TOPIC_OWNER
  STUDENT_REQUESTED
  FACULTY_ASSIGNED
}

enum SupervisorAssignmentStatus {
  ACTIVE
  CANCELLED
}

enum OutlineStatus {
  SUBMITTED
  NEEDS_REVISION
  APPROVED
  REJECTED
}

enum ProjectProgressStatus {
  SUBMITTED
  REVIEWED
}

enum FileDocumentType {
  OUTLINE
  PROGRESS_DRAFT
  REPORT
  SLIDE
  DEFENSE_DOCUMENT
  DEFENSE_REPORT_FINAL
  DEFENSE_SLIDE_FINAL
  DEFENSE_SUPPLEMENT
  DEFENSE_OTHER_DOCUMENT
  REVISION_REPORT
  FINAL_REPORT
  FINAL_SLIDE
  SOURCE_CODE
  ARCHIVE_DOCUMENT
  ARCHIVE_SUPPLEMENT
  ARCHIVE_OTHER
  REVISION
  ARCHIVE
  OTHER
}

enum DefenseRegistrationStatus {
  SUBMITTED
  NEEDS_REVISION
  APPROVED_BY_SUPERVISOR
  REJECTED_BY_SUPERVISOR
  SENT_TO_REVIEWER
  REVIEWER_NEEDS_REVISION
  APPROVED_BY_REVIEWER
  READY_FOR_COUNCIL
}

enum ReviewerAssignmentStatus {
  ASSIGNED
  CANCELLED
  COMPLETED
}

enum ReviewerEligibilityStatus {
  ELIGIBLE_FOR_DEFENSE
  NOT_ELIGIBLE_FOR_DEFENSE
}

enum DefenseCouncilStatus {
  DRAFT
  ACTIVE
  CLOSED
  CANCELLED
}

enum CouncilRole {
  CHAIR
  SECRETARY
  MEMBER
}

enum DefenseScheduleStatus {
  SCHEDULED
  DOCUMENT_PENDING
  DOCUMENT_NEEDS_SUPPLEMENT
  DOCUMENT_APPROVED
  CANCELLED
  COMPLETED
}

enum DefenseDocumentStatus {
  SUBMITTED
  NEEDS_SUPPLEMENT
  APPROVED
}

enum FinalResultStatus {
  PASSED
  FAILED
  PASSED_WITH_REVISION
}

enum ResultPublicationStatus {
  DRAFT
  CONFIRMED
  PUBLISHED
}

enum DefenseSessionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum RevisionRequestStatus {
  PENDING_SUBMISSION
  SUBMITTED
  NEEDS_CHANGES
  APPROVED
  CANCELLED
}

enum RevisionSubmissionStatus {
  SUBMITTED
  REVIEWED
}

enum ArchiveRecordStatus {
  NOT_SUBMITTED
  SUBMITTED
  NEEDS_SUPPLEMENT
  APPROVED
  COMPLETED
  LOCKED
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  fullName     String
  phone        String?
  avatarUrl    String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  userRoles UserRole[]
  auditLogs AuditLog[] @relation("AuditActor")
  student   Student?
  lecturer  Lecturer?

  createdProjectPeriods ProjectPeriod[] @relation("ProjectPeriodCreator")
  checkedEligibilities   StudentEligibility[] @relation("EligibilityChecker")
  approvedTopics         Topic[] @relation("TopicApprover")
  confirmedRegistrations TopicRegistration[] @relation("RegistrationConfirmer")
  assignedSupervisors    SupervisorAssignment[] @relation("SupervisorAssignmentAssigner")
  reviewedOutlines       Outline[] @relation("OutlineReviewer")
  progressComments       ProjectProgressComment[] @relation("ProgressCommenter")
  defenseReviews         DefenseRegistration[] @relation("DefenseSupervisorReviewer")
  reviewerAssignmentsMade ReviewerAssignment[] @relation("ReviewerAssignmentAssigner")
  ownedFileDocuments     FileDocument[] @relation("FileOwner")
  uploadedFileDocuments  FileDocument[] @relation("FileUploader")
  notifications          Notification[]
  createdDefenseCouncils DefenseCouncil[] @relation("DefenseCouncilCreator")
  createdDefenseSchedules DefenseSchedule[] @relation("DefenseScheduleCreator")
  councilMemberships     CouncilMember[]
  reviewedDefenseDocuments DefenseDocument[] @relation("DefenseDocumentSecretary")
  createdCouncilScores CouncilScore[] @relation("CouncilScoreCreator")
  calculatedScoreSummaries ScoreSummary[] @relation("ScoreSummaryCalculator")
  confirmedFinalResults FinalResult[] @relation("FinalResultConfirmer")
  publishedFinalResults FinalResult[] @relation("FinalResultPublisher")
  createdDefenseSessions DefenseSession[] @relation("DefenseSessionCreator")
  requestedRevisions RevisionRequest[] @relation("RevisionRequester")
  approvedRevisions RevisionRequest[] @relation("RevisionApprover")
  archiveStaffRecords ArchiveRecord[] @relation("ArchiveStaff")
  lockedProjectRecords ProjectRecordLock[] @relation("ProjectRecordLocker")

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model AuditLog {
  id         String      @id @default(uuid())
  actorId    String?
  actorEmail String?
  action     String
  targetType String?
  targetId   String?
  ipAddress  String?
  userAgent  String?
  result     AuditResult
  reason     String?
  createdAt  DateTime    @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Faculty {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students  Student[]
  lecturers Lecturer[]
  defenseCouncils DefenseCouncil[]

  @@map("faculties")
}

model Student {
  id               String           @id @default(uuid())
  userId           String           @unique
  studentCode      String           @unique
  className        String
  major            String
  facultyId        String?
  internshipStatus InternshipStatus @default(NOT_COMPLETED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  faculty               Faculty?               @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  eligibilities         StudentEligibility[]
  topicRegistrations    TopicRegistration[]
  supervisorAssignments SupervisorAssignment[]
  outlines              Outline[]
  projectProgresses     ProjectProgress[]
  defenseRegistrations DefenseRegistration[]
  reviewerAssignments  ReviewerAssignment[]
  defenseSchedules     DefenseSchedule[]
  defenseDocuments     DefenseDocument[]
  finalResults         FinalResult[]
  revisionRequests     RevisionRequest[]
  revisionSubmissions  RevisionSubmission[]
  archiveRecords       ArchiveRecord[]
  projectRecordLocks   ProjectRecordLock[]
  proposedTopics        Topic[]                @relation("TopicProposedByStudent")

  @@map("students")
}

model Lecturer {
  id                    String   @id @default(uuid())
  userId                String   @unique
  lecturerCode          String   @unique
  academicRank          String?
  department            String?
  facultyId             String?
  maxSupervisedStudents Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  faculty                      Faculty?               @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  topics                       Topic[]
  requestedTopicRegistrations  TopicRegistration[]
  supervisorAssignments        SupervisorAssignment[]
  supervisedOutlines           Outline[]
  supervisedProjectProgresses  ProjectProgress[]
  supervisedDefenseRegistrations DefenseRegistration[] @relation("DefenseSupervisor")
  reviewerAssignmentsAsSupervisor ReviewerAssignment[] @relation("ReviewerAssignmentSupervisor")
  reviewerAssignmentsAsReviewer ReviewerAssignment[] @relation("ReviewerAssignmentReviewer")
  reviewerEvaluations ReviewerEvaluation[]
  supervisorScores SupervisorScore[]
  reviewerScores ReviewerScore[]
  councilMemberships CouncilMember[]
  councilScores CouncilScore[]

  @@map("lecturers")
}

model ProjectPeriod {
  id                    String              @id @default(uuid())
  name                  String
  academicYear          String
  semester              String
  startDate             DateTime
  endDate               DateTime
  registrationStartDate DateTime?
  registrationEndDate   DateTime?
  status                ProjectPeriodStatus @default(DRAFT)
  createdById           String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  createdBy             User                   @relation("ProjectPeriodCreator", fields: [createdById], references: [id], onDelete: Restrict)
  eligibilities         StudentEligibility[]
  topics                Topic[]
  topicRegistrations    TopicRegistration[]
  supervisorAssignments SupervisorAssignment[]
  outlines              Outline[]
  projectProgresses     ProjectProgress[]
  defenseRegistrations  DefenseRegistration[]
  reviewerAssignments   ReviewerAssignment[]
  defenseCouncils       DefenseCouncil[]
  defenseSchedules      DefenseSchedule[]
  finalResults          FinalResult[]
  revisionRequests      RevisionRequest[]
  archiveRecords        ArchiveRecord[]
  projectRecordLocks    ProjectRecordLock[]

  @@map("project_periods")
}

model StudentEligibility {
  id                String            @id @default(uuid())
  studentId         String
  projectPeriodId   String
  internshipStatus  InternshipStatus
  academicStatus    AcademicStatus    @default(ACTIVE)
  eligibilityStatus EligibilityStatus @default(PENDING)
  reason            String?
  checkedById       String
  checkedAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  projectPeriod ProjectPeriod @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  checkedBy     User          @relation("EligibilityChecker", fields: [checkedById], references: [id], onDelete: Restrict)

  @@unique([studentId, projectPeriodId])
  @@map("student_eligibilities")
}

model Topic {
  id                  String      @id @default(uuid())
  title               String
  description         String
  objectives          String?
  expectedOutput      String?
  major               String?
  maxStudents         Int         @default(1)
  supervisorId        String
  projectPeriodId     String
  status              TopicStatus @default(DRAFT)
  source              TopicSource @default(SUPERVISOR_PROPOSED)
  proposedByStudentId String?
  rejectionReason     String?
  approvedById        String?
  approvedAt          DateTime?
  publishedAt         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  supervisor            Lecturer               @relation(fields: [supervisorId], references: [id], onDelete: Restrict)
  projectPeriod         ProjectPeriod          @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  proposedByStudent     Student?               @relation("TopicProposedByStudent", fields: [proposedByStudentId], references: [id], onDelete: SetNull)
  approvedBy            User?                  @relation("TopicApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  topicRegistrations    TopicRegistration[]
  supervisorAssignments SupervisorAssignment[]
  @@map("topics")
}

model TopicRegistration {
  id                       String                   @id @default(uuid())
  studentId                String
  projectPeriodId          String
  registrationType         TopicRegistrationType
  topicId                  String?
  proposedTitle            String?
  proposedDescription      String?
  proposedObjectives       String?
  proposedExpectedOutput   String?
  proposedMajor            String?
  requestedSupervisorId    String?
  supervisorResponseStatus SupervisorResponseStatus @default(NOT_REQUIRED)
  supervisorResponseNote   String?
  status                   TopicRegistrationStatus  @default(DRAFT)
  facultyNote              String?
  rejectedReason           String?
  confirmedById            String?
  confirmedAt              DateTime?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  student             Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  projectPeriod       ProjectPeriod         @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  topic               Topic?                @relation(fields: [topicId], references: [id], onDelete: SetNull)
  requestedSupervisor Lecturer?             @relation(fields: [requestedSupervisorId], references: [id], onDelete: SetNull)
  confirmedBy         User?                 @relation("RegistrationConfirmer", fields: [confirmedById], references: [id], onDelete: SetNull)
  supervisorAssignment SupervisorAssignment?
  outline              Outline?
  defenseRegistration  DefenseRegistration?

  @@index([studentId, projectPeriodId])
  @@index([status])
  @@map("topic_registrations")
}

model SupervisorAssignment {
  id                  String                     @id @default(uuid())
  topicRegistrationId String                     @unique
  studentId           String
  topicId             String?
  projectPeriodId     String
  supervisorId        String
  assignedById        String
  assignmentType      SupervisorAssignmentType
  status              SupervisorAssignmentStatus @default(ACTIVE)
  assignedAt          DateTime                   @default(now())
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  topicRegistration TopicRegistration @relation(fields: [topicRegistrationId], references: [id], onDelete: Cascade)
  student           Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  topic             Topic?            @relation(fields: [topicId], references: [id], onDelete: SetNull)
  projectPeriod     ProjectPeriod     @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  supervisor        Lecturer          @relation(fields: [supervisorId], references: [id], onDelete: Restrict)
  assignedBy        User              @relation("SupervisorAssignmentAssigner", fields: [assignedById], references: [id], onDelete: Restrict)
  outlines          Outline[]
  projectProgresses ProjectProgress[]
  defenseRegistrations DefenseRegistration[]

  @@unique([studentId, projectPeriodId])
  @@index([supervisorId])
  @@map("supervisor_assignments")
}

model Outline {
  id                     String        @id @default(uuid())
  topicRegistrationId    String        @unique
  supervisorAssignmentId String
  studentId              String
  supervisorId           String
  projectPeriodId        String
  title                  String
  summary                String
  objectives             String?
  methodology            String?
  expectedOutput         String?
  timeline               String?
  status                 OutlineStatus @default(SUBMITTED)
  currentVersion         Int           @default(1)
  submittedAt            DateTime      @default(now())
  reviewedAt             DateTime?
  reviewedById           String?
  feedback               String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  topicRegistration    TopicRegistration    @relation(fields: [topicRegistrationId], references: [id], onDelete: Cascade)
  supervisorAssignment SupervisorAssignment @relation(fields: [supervisorAssignmentId], references: [id], onDelete: Cascade)
  student              Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  supervisor           Lecturer             @relation(fields: [supervisorId], references: [id], onDelete: Restrict)
  projectPeriod        ProjectPeriod        @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  reviewedBy           User?                @relation("OutlineReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  versions             OutlineVersion[]
  defenseRegistrations DefenseRegistration[]

  @@index([studentId])
  @@index([supervisorId])
  @@index([status])
  @@map("outlines")
}

model OutlineVersion {
  id             String   @id @default(uuid())
  outlineId      String
  versionNumber  Int
  title          String
  summary        String
  objectives     String?
  methodology    String?
  expectedOutput String?
  timeline       String?
  fileDocumentId String?
  submitNote     String?
  submittedAt    DateTime @default(now())
  createdAt      DateTime @default(now())

  outline      Outline       @relation(fields: [outlineId], references: [id], onDelete: Cascade)
  fileDocument FileDocument? @relation("OutlineVersionFile", fields: [fileDocumentId], references: [id], onDelete: SetNull)

  @@unique([outlineId, versionNumber])
  @@map("outline_versions")
}

model ProjectProgress {
  id                     String                @id @default(uuid())
  studentId              String
  supervisorId           String
  supervisorAssignmentId String
  projectPeriodId        String
  title                  String
  content                String
  progressPercent        Int?
  status                 ProjectProgressStatus @default(SUBMITTED)
  fileDocumentId         String?
  submittedAt            DateTime              @default(now())
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  student              Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  supervisor           Lecturer             @relation(fields: [supervisorId], references: [id], onDelete: Restrict)
  supervisorAssignment SupervisorAssignment @relation(fields: [supervisorAssignmentId], references: [id], onDelete: Cascade)
  projectPeriod        ProjectPeriod        @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  fileDocument         FileDocument?        @relation("ProjectProgressFile", fields: [fileDocumentId], references: [id], onDelete: SetNull)
  comments             ProjectProgressComment[]

  @@index([studentId])
  @@index([supervisorId])
  @@index([supervisorAssignmentId])
  @@map("project_progress")
}

model ProjectProgressComment {
  id          String   @id @default(uuid())
  progressId  String
  commenterId String
  comment     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress  ProjectProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  commenter User            @relation("ProgressCommenter", fields: [commenterId], references: [id], onDelete: Cascade)

  @@index([progressId])
  @@map("project_progress_comments")
}

model FileDocument {
  id           String           @id @default(uuid())
  ownerId      String
  originalName String
  storedName   String
  bucket       String
  objectKey    String
  mimeType     String
  size         Int
  fileType     FileDocumentType @default(OTHER)
  relatedType  String?
  relatedId    String?
  uploadedById String
  createdAt    DateTime         @default(now())
  deletedAt    DateTime?

  owner                User              @relation("FileOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  uploadedBy           User              @relation("FileUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  outlineVersions      OutlineVersion[]  @relation("OutlineVersionFile")
  projectProgressItems ProjectProgress[] @relation("ProjectProgressFile")
  defenseReportRegistrations DefenseRegistration[] @relation("DefenseReportFile")
  defenseSlideRegistrations DefenseRegistration[] @relation("DefenseSlideFile")
  defenseAdditionalDocumentRegistrations DefenseRegistration[] @relation("DefenseAdditionalDocumentFile")
  defenseDocumentReports DefenseDocument[] @relation("DefenseDocumentReportFile")
  defenseDocumentSlides DefenseDocument[] @relation("DefenseDocumentSlideFile")
  defenseDocumentAdditional DefenseDocument[] @relation("DefenseDocumentAdditionalFile")
  revisionSubmissions RevisionSubmission[] @relation("RevisionSubmissionReportFile")
  archiveFinalReports ArchiveRecord[] @relation("ArchiveFinalReportFile")
  archiveFinalSlides ArchiveRecord[] @relation("ArchiveFinalSlideFile")
  archiveSourceCodes ArchiveRecord[] @relation("ArchiveSourceCodeFile")
  archiveAdditionalDocuments ArchiveRecord[] @relation("ArchiveAdditionalDocumentFile")

  @@index([ownerId])
  @@index([relatedType, relatedId])
  @@map("file_documents")
}


model DefenseRegistration {
  id                       String                    @id @default(uuid())
  studentId                String
  supervisorId             String
  supervisorAssignmentId   String
  topicRegistrationId      String                    @unique
  outlineId                String
  projectPeriodId          String
  reportFileId             String?
  slideFileId              String?
  additionalDocumentFileId String?
  title                    String
  summary                  String?
  studentNote              String?
  status                   DefenseRegistrationStatus @default(SUBMITTED)
  supervisorFeedback       String?
  supervisorReviewedAt     DateTime?
  supervisorReviewedById   String?
  submittedAt              DateTime                  @default(now())
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  student                  Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  supervisor               Lecturer             @relation("DefenseSupervisor", fields: [supervisorId], references: [id], onDelete: Restrict)
  supervisorAssignment     SupervisorAssignment @relation(fields: [supervisorAssignmentId], references: [id], onDelete: Cascade)
  topicRegistration        TopicRegistration    @relation(fields: [topicRegistrationId], references: [id], onDelete: Cascade)
  outline                  Outline              @relation(fields: [outlineId], references: [id], onDelete: Cascade)
  projectPeriod            ProjectPeriod        @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  reportFile               FileDocument?        @relation("DefenseReportFile", fields: [reportFileId], references: [id], onDelete: SetNull)
  slideFile                FileDocument?        @relation("DefenseSlideFile", fields: [slideFileId], references: [id], onDelete: SetNull)
  additionalDocumentFile   FileDocument?        @relation("DefenseAdditionalDocumentFile", fields: [additionalDocumentFileId], references: [id], onDelete: SetNull)
  supervisorReviewedBy     User?                @relation("DefenseSupervisorReviewer", fields: [supervisorReviewedById], references: [id], onDelete: SetNull)
  reviewerAssignment       ReviewerAssignment?
  reviewerEvaluations      ReviewerEvaluation[]
  supervisorScore          SupervisorScore?
  defenseSchedule          DefenseSchedule?
  defenseDocument          DefenseDocument?
  councilScores            CouncilScore[]
  scoreSummary             ScoreSummary?
  finalResult              FinalResult?
  defenseSession           DefenseSession?
  revisionRequests         RevisionRequest[]
  archiveRecords           ArchiveRecord[]

  @@unique([studentId, projectPeriodId])
  @@index([supervisorId])
  @@index([status])
  @@map("defense_registrations")
}

model ReviewerAssignment {
  id                    String                   @id @default(uuid())
  defenseRegistrationId String                   @unique
  studentId             String
  projectPeriodId       String
  supervisorId          String
  reviewerId            String
  assignedById          String
  status                ReviewerAssignmentStatus @default(ASSIGNED)
  assignedAt            DateTime                 @default(now())
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  defenseRegistration DefenseRegistration @relation(fields: [defenseRegistrationId], references: [id], onDelete: Cascade)
  student             Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  projectPeriod       ProjectPeriod       @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  supervisor          Lecturer            @relation("ReviewerAssignmentSupervisor", fields: [supervisorId], references: [id], onDelete: Restrict)
  reviewer            Lecturer            @relation("ReviewerAssignmentReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)
  assignedBy          User                @relation("ReviewerAssignmentAssigner", fields: [assignedById], references: [id], onDelete: Restrict)
  evaluation          ReviewerEvaluation?
  reviewerScore       ReviewerScore?

  @@index([reviewerId])
  @@index([projectPeriodId])
  @@map("reviewer_assignments")
}

model ReviewerEvaluation {
  id                    String                    @id @default(uuid())
  reviewerAssignmentId  String                    @unique
  reviewerId            String
  defenseRegistrationId String
  comment               String
  strengths             String?
  weaknesses            String?
  questionSuggestions   String?
  eligibilityStatus     ReviewerEligibilityStatus
  feedbackToStudent     String?
  submittedAt           DateTime                  @default(now())
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  reviewerAssignment  ReviewerAssignment  @relation(fields: [reviewerAssignmentId], references: [id], onDelete: Cascade)
  reviewer            Lecturer            @relation(fields: [reviewerId], references: [id], onDelete: Restrict)
  defenseRegistration DefenseRegistration @relation(fields: [defenseRegistrationId], references: [id], onDelete: Cascade)

  @@index([reviewerId])
  @@map("reviewer_evaluations")
}

model SupervisorScore {
  id                    String   @id @default(uuid())
  defenseRegistrationId String   @unique
  supervisorId          String
  score                 Float
  comment               String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  defenseRegistration DefenseRegistration @relation(fields: [defenseRegistrationId], references: [id], onDelete: Cascade)
  supervisor          Lecturer            @relation(fields: [supervisorId], references: [id], onDelete: Restrict)

  @@index([supervisorId])
  @@map("supervisor_scores")
}

model ReviewerScore {
  id                   String   @id @default(uuid())
  reviewerAssignmentId String   @unique
  reviewerId           String
  score                Float
  comment              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  reviewerAssignment ReviewerAssignment @relation(fields: [reviewerAssignmentId], references: [id], onDelete: Cascade)
  reviewer           Lecturer           @relation(fields: [reviewerId], references: [id], onDelete: Restrict)

  @@index([reviewerId])
  @@map("reviewer_scores")
}

model DefenseCouncil {
  id              String               @id @default(uuid())
  name            String
  projectPeriodId String
  facultyId       String?
  description     String?
  status          DefenseCouncilStatus @default(DRAFT)
  createdById     String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  projectPeriod ProjectPeriod    @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  faculty       Faculty?         @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  createdBy     User             @relation("DefenseCouncilCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members       CouncilMember[]
  schedules     DefenseSchedule[]
  councilScores CouncilScore[]
  defenseSessions DefenseSession[]

  @@index([projectPeriodId])
  @@index([status])
  @@map("defense_councils")
}

model CouncilMember {
  id            String      @id @default(uuid())
  councilId     String
  lecturerId    String
  userId        String
  roleInCouncil CouncilRole
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  council  DefenseCouncil @relation(fields: [councilId], references: [id], onDelete: Cascade)
  lecturer Lecturer       @relation(fields: [lecturerId], references: [id], onDelete: Restrict)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  councilScores CouncilScore[]

  @@unique([councilId, lecturerId])
  @@index([userId])
  @@index([roleInCouncil])
  @@map("council_members")
}

model DefenseSchedule {
  id                    String                @id @default(uuid())
  defenseRegistrationId String                @unique
  studentId             String
  projectPeriodId       String
  councilId             String
  room                  String
  defenseDate           DateTime
  startTime             DateTime
  endTime               DateTime
  status                DefenseScheduleStatus @default(SCHEDULED)
  createdById           String
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  defenseRegistration DefenseRegistration @relation(fields: [defenseRegistrationId], references: [id], onDelete: Cascade)
  student             Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  projectPeriod       ProjectPeriod       @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  council             DefenseCouncil      @relation(fields: [councilId], references: [id], onDelete: Restrict)
  createdBy           User                @relation("DefenseScheduleCreator", fields: [createdById], references: [id], onDelete: Restrict)
  defenseDocument     DefenseDocument?
  councilScores       CouncilScore[]
  scoreSummary        ScoreSummary?
  finalResult         FinalResult?
  defenseSession      DefenseSession?
  revisionRequests    RevisionRequest[]

  @@index([studentId])
  @@index([councilId])
  @@index([projectPeriodId])
  @@index([status])
  @@map("defense_schedules")
}

model DefenseDocument {
  id                    String                @id @default(uuid())
  defenseScheduleId     String                @unique
  defenseRegistrationId String                @unique
  studentId             String
  reportFileId          String?
  slideFileId           String?
  additionalFileId      String?
  status                DefenseDocumentStatus @default(SUBMITTED)
  secretaryId           String?
  secretaryNote         String?
  reviewedAt            DateTime?
  submittedAt           DateTime              @default(now())
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  defenseSchedule     DefenseSchedule      @relation(fields: [defenseScheduleId], references: [id], onDelete: Cascade)
  defenseRegistration DefenseRegistration  @relation(fields: [defenseRegistrationId], references: [id], onDelete: Cascade)
  student             Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reportFile          FileDocument?        @relation("DefenseDocumentReportFile", fields: [reportFileId], references: [id], onDelete: SetNull)
  slideFile           FileDocument?        @relation("DefenseDocumentSlideFile", fields: [slideFileId], references: [id], onDelete: SetNull)
  additionalFile      FileDocument?        @relation("DefenseDocumentAdditionalFile", fields: [additionalFileId], references: [id], onDelete: SetNull)
  secretary           User?                @relation("DefenseDocumentSecretary", fields: [secretaryId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([status])
  @@map("defense_documents")
}


model CouncilScore {
  id                    String   @id @default(uuid())
  defenseScheduleId     String
  defenseRegistrationId String
  councilId             String
  councilMemberId       String
  lecturerId            String
  score                 Float
  comment               String?
  createdById           String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  defenseSchedule     DefenseSchedule      @relation(fields: [defenseScheduleId], references: [id], onDelete: Cascade)
  defenseRegistration DefenseRegistration  @relation(fields: [defenseRegistrationId], references: [id], onDelete: Cascade)
  council             DefenseCouncil       @relation(fields: [councilId], references: [id], onDelete: Cascade)
  councilMember       CouncilMember        @relation(fields: [councilMemberId], references: [id], onDelete: Cascade)
  lecturer            Lecturer             @relation(fields: [lecturerId], references: [id], onDelete: Restrict)
  createdBy           User                 @relation("CouncilScoreCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([defenseScheduleId, councilMemberId])
  @@index([defenseRegistrationId])
  @@index([councilId])
  @@map("council_scores")
}

model ScoreSummary {
  id                    String   @id @default(uuid())
  defenseRegistrationId String   @unique
  defenseScheduleId     String   @unique
  supervisorScore       Float
  reviewerScore         Float
  councilAverageScore   Float
  finalScore            Float
  calculatedById        String
  calculatedAt          DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  defenseRegistration DefenseRegistration @relation(fields: [defenseRegistrationId], references: [id], onDelete: Cascade)
  defenseSchedule     DefenseSchedule     @relation(fields: [defenseScheduleId], references: [id], onDelete: Cascade)
  calculatedBy        User                @relation("ScoreSummaryCalculator", fields: [calculatedById], references: [id], onDelete: Restrict)

  @@map("score_summaries")
}

model FinalResult {
  id                    String                  @id @default(uuid())
  defenseRegistrationId String                  @unique
  defenseScheduleId     String                  @unique
  studentId             String
  projectPeriodId       String
  supervisorScore       Float
  reviewerScore         Float
  councilAverageScore   Float
  finalScore            Float
  resultStatus          FinalResultStatus
  publicationStatus     ResultPublicationStatus @default(DRAFT)
  revisionRequired      Boolean                 @default(false)
  revisionNote          String?
  confirmedById         String?
  confirmedAt           DateTime?
  publishedById         String?
  publishedAt           DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  defenseRegistration DefenseRegistration @relation(fields: [defenseRegistrationId], references: [id], onDelete: Cascade)
  defenseSchedule     DefenseSchedule     @relation(fields: [defenseScheduleId], references: [id], onDelete: Cascade)
  student             Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  projectPeriod       ProjectPeriod       @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  confirmedBy         User?               @relation("FinalResultConfirmer", fields: [confirmedById], references: [id], onDelete: SetNull)
  publishedBy         User?               @relation("FinalResultPublisher", fields: [publishedById], references: [id], onDelete: SetNull)
  revisionRequest     RevisionRequest?
  archiveRecord       ArchiveRecord?
  projectRecordLock   ProjectRecordLock?

  @@index([studentId])
  @@index([publicationStatus])
  @@index([resultStatus])
  @@map("final_results")
}

model DefenseSession {
  id                    String               @id @default(uuid())
  defenseScheduleId     String               @unique
  defenseRegistrationId String               @unique
  councilId             String
  sessionStatus         DefenseSessionStatus @default(NOT_STARTED)
  generalComment        String?
  conclusion            String?
  revisionRequired      Boolean              @default(false)
  revisionNote          String?
  createdById           String
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  defenseSchedule     DefenseSchedule     @relation(fields: [defenseScheduleId], references: [id], onDelete: Cascade)
  defenseRegistration DefenseRegistration @relation(fields: [defenseRegistrationId], references: [id], onDelete: Cascade)
  council             DefenseCouncil      @relation(fields: [councilId], references: [id], onDelete: Cascade)
  createdBy           User                @relation("DefenseSessionCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([councilId])
  @@map("defense_sessions")
}


model RevisionRequest {
  id                    String                @id @default(uuid())
  finalResultId          String                @unique
  defenseRegistrationId  String
  defenseScheduleId      String?
  studentId              String
  projectPeriodId        String
  requestedById          String
  title                  String
  description            String
  status                 RevisionRequestStatus @default(PENDING_SUBMISSION)
  dueDate                DateTime?
  approvedById           String?
  approvedAt             DateTime?
  feedback               String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  finalResult         FinalResult         @relation(fields: [finalResultId], references: [id], onDelete: Cascade)
  defenseRegistration DefenseRegistration @relation(fields: [defenseRegistrationId], references: [id], onDelete: Cascade)
  defenseSchedule     DefenseSchedule?    @relation(fields: [defenseScheduleId], references: [id], onDelete: SetNull)
  student             Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  projectPeriod       ProjectPeriod       @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  requestedBy         User                @relation("RevisionRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  approvedBy          User?               @relation("RevisionApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  submissions         RevisionSubmission[]
  archiveRecord       ArchiveRecord?

  @@index([studentId])
  @@index([status])
  @@map("revision_requests")
}

model RevisionSubmission {
  id                 String                   @id @default(uuid())
  revisionRequestId  String
  studentId           String
  versionNumber       Int
  reportFileId        String?
  note                String?
  status              RevisionSubmissionStatus @default(SUBMITTED)
  submittedAt         DateTime                 @default(now())
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  revisionRequest RevisionRequest @relation(fields: [revisionRequestId], references: [id], onDelete: Cascade)
  student         Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reportFile      FileDocument?   @relation("RevisionSubmissionReportFile", fields: [reportFileId], references: [id], onDelete: SetNull)

  @@unique([revisionRequestId, versionNumber])
  @@index([studentId])
  @@map("revision_submissions")
}

model ArchiveRecord {
  id                       String              @id @default(uuid())
  finalResultId             String              @unique
  defenseRegistrationId     String
  studentId                 String
  projectPeriodId           String
  revisionRequestId         String?             @unique
  finalReportFileId         String?
  finalSlideFileId          String?
  sourceCodeFileId          String?
  additionalDocumentFileId  String?
  status                    ArchiveRecordStatus @default(NOT_SUBMITTED)
  archiveStaffId            String?
  archiveNote               String?
  supplementReason          String?
  submittedAt               DateTime?
  approvedAt                DateTime?
  completedAt               DateTime?
  lockedAt                  DateTime?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  finalResult         FinalResult         @relation(fields: [finalResultId], references: [id], onDelete: Cascade)
  defenseRegistration DefenseRegistration @relation(fields: [defenseRegistrationId], references: [id], onDelete: Cascade)
  student             Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  projectPeriod       ProjectPeriod       @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  revisionRequest     RevisionRequest?    @relation(fields: [revisionRequestId], references: [id], onDelete: SetNull)
  archiveStaff        User?               @relation("ArchiveStaff", fields: [archiveStaffId], references: [id], onDelete: SetNull)
  finalReportFile     FileDocument?       @relation("ArchiveFinalReportFile", fields: [finalReportFileId], references: [id], onDelete: SetNull)
  finalSlideFile      FileDocument?       @relation("ArchiveFinalSlideFile", fields: [finalSlideFileId], references: [id], onDelete: SetNull)
  sourceCodeFile      FileDocument?       @relation("ArchiveSourceCodeFile", fields: [sourceCodeFileId], references: [id], onDelete: SetNull)
  additionalDocumentFile FileDocument?    @relation("ArchiveAdditionalDocumentFile", fields: [additionalDocumentFileId], references: [id], onDelete: SetNull)
  projectRecordLock   ProjectRecordLock?

  @@index([studentId])
  @@index([status])
  @@map("archive_records")
}

model ProjectRecordLock {
  id              String   @id @default(uuid())
  studentId       String
  projectPeriodId String
  finalResultId   String   @unique
  archiveRecordId String   @unique
  lockedById      String
  reason          String
  lockedAt        DateTime @default(now())
  createdAt       DateTime @default(now())

  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  projectPeriod ProjectPeriod @relation(fields: [projectPeriodId], references: [id], onDelete: Cascade)
  finalResult   FinalResult   @relation(fields: [finalResultId], references: [id], onDelete: Cascade)
  archiveRecord ArchiveRecord @relation(fields: [archiveRecordId], references: [id], onDelete: Cascade)
  lockedBy      User          @relation("ProjectRecordLocker", fields: [lockedById], references: [id], onDelete: Restrict)

  @@unique([studentId, projectPeriodId])
  @@map("project_record_locks")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}
